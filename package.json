{
  "name": "json-cv",
  "version": "1.0.0",
  "description": "A CLI tool to generate ATS-friendly resumes from IETF JSON Resume format using Handlebars templates and Puppeteer for PDF output.",
  "main": "src/build.js",
  "bin": {
    "json-cv": "./bin/json-cv"
  },
  "scripts": {
    "build": "node bin/json-cv --input examples/resume.json --template templates/default.hbs --out dist/resume.pdf",
    "preview": "node bin/json-cv --input examples/resume.json --template templates/default.hbs --preview",
    "validate": "node bin/json-cv --input examples/resume.json --validate"
  },
  "keywords": [
    "resume",
    "cv",
    "json",
    "pdf",
    "ats",
    "handlebars",
    "puppeteer"
  ],
  "author": "Luminaw",
  "license": "MIT",
  "dependencies": {},
  "devDependencies": {},
  "engines": {
    "node": ">=16.0.0"
  }
}