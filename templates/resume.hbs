<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <title>{{basics.name}} - Resume</title>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <style>
    {{{style}}}
  </style>
</head>
<body>
  <header class="header">
    <h1>{{basics.name}}</h1>
    <div class="contact-info">
      {{#if basics.location.city}}
        <span>
          <i class="fas fa-map-marker-alt" aria-hidden="true"></i> 
          {{basics.location.city}}{{#if basics.location.region}}, {{basics.location.region}}{{/if}}&nbsp;<span class="sr-only">{{#if basics.location.postalCode}}{{basics.location.postalCode}}{{/if}} {{#if basics.location.countryCode}}{{basics.location.countryCode}}{{/if}}</span>
        </span>
      {{/if}}
      {{#if basics.phone}}
        <span><i class="fas fa-phone" aria-hidden="true"></i> {{basics.phone}}</span>
      {{/if}}
      {{#if basics.email}}
        <span><i class="fas fa-envelope" aria-hidden="true"></i> <a href="mailto:{{basics.email}}">{{basics.email}}</a></span>
      {{/if}}
      {{#if basics.url}}
        <span><i class="fas fa-globe" aria-hidden="true"></i> <a href="{{basics.url}}">{{basics.url}}</a></span>
      {{/if}}
      {{#if basics.profiles.length}}
        {{#each basics.profiles}}
          <span><i class="{{iconForNetwork network}}" aria-hidden="true"></i> <a href="{{url}}"><span class="sr-only">{{network}}: </span>{{#if username}}{{username}}{{else}}{{network}}{{/if}}</a></span>
        {{/each}}
      {{/if}}
    </div>
  </header>

  {{#if basics.summary}}
  <section id="summary">
    <h2>Professional Summary</h2>
    <p class="summary">{{basics.summary}}</p>
  </section>
  {{/if}}

  {{#if work.length}}
  <section id="experience">
    <h2>Professional Experience</h2>
    {{#each work}}
    <div class="item">
      <div class="item-header">
        <div class="title-group">
          <h3>{{position}}<span class="separator">, </span><span class="entity-name">{{name}}</span></h3>
        </div>
        <span class="date">{{formatDate startDate}} - {{#if endDate}}{{formatDate endDate}}{{else}}Present{{/if}}</span>
      </div>
      {{#if summary}}<div class="job-summary">{{summary}}</div>{{/if}}
      {{#if highlights.length}}
      <ul>
        {{#each highlights}}
        <li>{{this}}</li>
        {{/each}}
      </ul>
      {{/if}}
    </div>
    <div class="sr-only">&nbsp;</div>
    {{/each}}
  </section>
  {{/if}}

  {{#if volunteer.length}}
  <section id="volunteer">
    <h2>Volunteer Experience</h2>
    {{#each volunteer}}
    <div class="item">
      <div class="item-header">
        <div class="title-group">
          <h3>{{position}}<span class="separator">, </span><span class="entity-name">{{organization}}</span></h3>
        </div>
        <span class="date">{{formatDate startDate}} - {{#if endDate}}{{formatDate endDate}}{{else}}Present{{/if}}</span>
      </div>
      {{#if summary}}<div class="job-summary">{{summary}}</div>{{/if}}
      {{#if highlights.length}}
      <ul>
        {{#each highlights}}
        <li>{{this}}</li>
        {{/each}}
      </ul>
      {{/if}}
    </div>
    {{/each}}
  </section>
  <div class="sr-only">&nbsp;</div>
  {{/if}}

  {{#if projects.length}}
  <section id="projects">
    <h2>Projects</h2>
    {{#each projects}}
    <div class="item">
      <div class="item-header">
        <h3>{{name}}</h3>
        <span class="date">{{formatDate startDate}} - {{#if endDate}}{{formatDate endDate}}{{else}}Present{{/if}}</span>
      </div>
      {{#if roles.length}}
      <p><strong>Roles:</strong> {{#each roles}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}</p>
      {{/if}}
      {{#if description}}<p class="summary">{{description}}</p>{{/if}}
      {{#if highlights.length}}
      <ul>
        {{#each highlights}}
        <li>{{this}}</li>
        {{/each}}
      </ul>
      {{/if}}
      {{#if keywords.length}}
      <p class="skill-keywords"><em>Keywords: {{#each keywords}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}</em></p>
      {{/if}}
    </div>
    {{/each}}
  </section>
  {{/if}}

  {{#if skills.length}}
  <section id="skills">
    <h2>Technical Skills</h2>
    <div class="skills-list">
      {{#each skills}}
      <div class="item">
        <span class="skill-category">{{name}}:</span>
        <span class="skill-keywords">{{#each keywords}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}</span>
      </div>
      {{/each}}
    </div>
  </section>
  <div class="sr-only">&nbsp;</div>
  {{/if}}

  {{#if education.length}}
  <section id="education">
    <h2>Education</h2>
    {{#each education}}
    <div class="item">
      <div class="item-header">
        <div class="title-group">
          <h3>{{studyType}}{{#if area}} in {{area}}{{/if}}<span class="separator">, </span><span class="entity-name">{{institution}}</span></h3>
        </div>
        <span class="date">{{formatDate startDate}} - {{#if endDate}}{{formatDate endDate}}{{else}}Present{{/if}}</span>
      </div>
      {{#if score}}<div class="gpa">GPA: {{score}}</div>{{/if}}
      {{#if courses.length}}
      <div class="courses">Notable Courses: {{#each courses}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}</div>
      {{/if}}
    </div>
    {{/each}}
  </section>
  <div class="sr-only">&nbsp;</div>
  {{/if}}

  {{#if awards.length}}
  <section id="awards">
    <h2>Awards</h2>
    {{#each awards}}
    <div class="item">
      <div class="item-header">
        <div class="title-group">
          <h3>{{title}}<span class="separator">, </span><span class="entity-name">{{awarder}}</span></h3>
        </div>
        <span class="date">{{date}}</span>
      </div>
      {{#if summary}}<p class="summary">{{summary}}</p>{{/if}}
    </div>
    {{/each}}
  </section>
  {{/if}}

  {{#if certificates.length}}
  <section id="certificates">
    <h2>Certifications</h2>
    {{#each certificates}}
    <div class="item">
      <div class="item-header">
        <div class="title-group">
          <h3>{{name}}<span class="separator">, </span><span class="entity-name">{{issuer}}</span></h3>
        </div>
        <span class="date">{{date}}</span>
      </div>
    </div>
    {{/each}}
  </section>
  <div class="sr-only">&nbsp;</div>
  {{/if}}

  {{#if publications.length}}
  <section id="publications">
    <h2>Publications</h2>
    {{#each publications}}
    <div class="item">
      <div class="item-header">
        <h3>{{name}}</h3>
        <span class="date">{{formatDate releaseDate}}</span>
      </div>
      <p>{{publisher}}{{#if summary}} - {{summary}}{{/if}}</p>
    </div>
    {{/each}}
  </section>
  {{/if}}

  {{#if languages.length}}
  <section id="languages">
    <h2>Languages</h2>
    <div class="skills-list">
      {{#each languages}}
      <div class="item">
        <span class="skill-category">{{language}}:</span>
        <span class="skill-keywords">{{fluency}}</span>
      </div>
      {{/each}}
    </div>
  </section>
  <div class="sr-only">&nbsp;</div>
  {{/if}}

  {{#if interests.length}}
  <section id="interests">
    <h2>Interests</h2>
    <div class="skills-list">
      {{#each interests}}
      <div class="item">
        <span class="skill-category">{{name}}:</span>
        <span class="skill-keywords">{{#each keywords}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}</span>
      </div>
      {{/each}}
    </div>
  </section>
  <div class="sr-only">&nbsp;</div>
  {{/if}}

  {{#if references.length}}
  <section id="references">
    <h2>References</h2>
    {{#each references}}
    <div class="item">
      <div class="reference-item">
        <div class="reference-name"><strong>{{name}}</strong></div>
        {{#if reference}}<div class="reference-text"><em>"{{reference}}"</em></div>{{/if}}
      </div>
    </div>
    {{/each}}
  </section>
  {{/if}}

</body>
</html>
