<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{basics.name}} - Resume</title>
  <style>
    @page {
      size: A4;
      margin: 0;
    }
    body {
      font-family: Arial, sans-serif;
      line-height: 1.2;
      color: #333;
      max-width: 210mm;
      margin: 0 auto;
      padding: 5mm;
      background: white;
      font-size: 10px;
    }
    header {
      text-align: center;
      margin-bottom: 5px;
    }
    h1 {
      margin: 0;
      font-size: 14px;
    }
    h2 {
      font-size: 12px;
      border-bottom: 1px solid #ccc;
      padding-bottom: 2px;
      margin-top: 10px;
      margin-bottom: 3px;
    }
    h3 {
      font-size: 10px;
      margin: 3px 0 2px 0;
    }
    section {
      margin-bottom: 5px;
    }
    ul {
      margin: 0;
      padding-left: 15px;
    }
    li {
      margin-bottom: 2px;
    }
    .contact {
      margin-bottom: 10px;
    }
    .contact span {
      display: inline-block;
      margin-right: 15px;
    }
    .date {
      font-style: italic;
      color: #666;
    }
    .hidden {
      position: absolute;
      left: -10000px;
      top: auto;
      width: 1px;
      height: 1px;
      overflow: hidden;
    }
  </style>
</head>
<body>
  <header>
    <h1>{{basics.name}}</h1>
    {{#if basics.label}}<p>{{basics.label}}</p>{{/if}}
    <div class="contact">
      {{#if basics.email}}<span>Email: {{basics.email}}</span>{{/if}}
      {{#if basics.phone}}<span>Phone: {{basics.phone}}</span>{{/if}}
      {{#if basics.url}}<span>Website: {{basics.url}}</span>{{/if}}
      {{#if basics.location}}
        <span>Location: {{#if basics.location.city}}{{basics.location.city}}, {{/if}}{{#if basics.location.region}}{{basics.location.region}}, {{/if}}{{basics.location.countryCode}}</span>
      {{/if}}
    </div>
    {{#each basics.profiles}}
      <div class="contact">
        <span>{{network}}: {{username}} {{#if url}}({{url}}){{/if}}</span>
      </div>
    {{/each}}
  </header>

  {{#if basics.summary}}
  <section>
    <h2>Summary</h2>
    <p>{{basics.summary}}</p>
  </section>
  {{/if}}

  {{#if work}}
  <section>
    <h2>Work Experience</h2>
    {{#each work}}
    <div>
      <h3>{{position}} at {{name}}</h3>
      <p class="date">{{#if startDate}}{{startDate}} - {{/if}}{{#if endDate}}{{endDate}}{{else}}Present{{/if}}</p>
      {{#if url}}<p><a href="{{url}}">{{url}}</a></p>{{/if}}
      {{#if summary}}<p>{{summary}}</p>{{/if}}
      {{#if highlights}}
      <ul>
        {{#each highlights}}
        <li>{{this}}</li>
        {{/each}}
      </ul>
      {{/if}}
    </div>
    {{/each}}
  </section>
  {{/if}}

  {{#if education}}
  <section>
    <h2>Education</h2>
    {{#each education}}
    <div>
      <h3>{{studyType}} in {{area}} at {{institution}}</h3>
      <p class="date">{{#if startDate}}{{startDate}} - {{/if}}{{#if endDate}}{{endDate}}{{else}}Present{{/if}}</p>
      {{#if url}}<p><a href="{{url}}">{{url}}</a></p>{{/if}}
      {{#if score}}<p>GPA: {{score}}</p>{{/if}}
      {{#if courses}}
      <p>Courses: {{join courses ", "}}</p>
      {{/if}}
    </div>
    {{/each}}
  </section>
  {{/if}}

  {{#if skills}}
  <section>
    <h2>Skills</h2>
    {{#each skills}}
    <div>
      <h3>{{name}}</h3>
      {{#if level}}<p>Level: {{level}}</p>{{/if}}
      {{#if keywords}}
      <p>{{join keywords ", "}}</p>
      {{/if}}
    </div>
    {{/each}}
  </section>
  {{/if}}

  {{#if projects}}
  <section>
    <h2>Projects</h2>
    {{#each projects}}
    <div>
      <h3>{{name}}</h3>
      {{#if description}}<p>{{description}}</p>{{/if}}
      {{#if highlights}}
      <ul>
        {{#each highlights}}
        <li>{{this}}</li>
        {{/each}}
      </ul>
      {{/if}}
      {{#if keywords}}<p>Technologies: {{join keywords ", "}}</p>{{/if}}
      <p class="date">{{#if startDate}}{{startDate}} - {{/if}}{{#if endDate}}{{endDate}}{{else}}Present{{/if}}</p>
      {{#if url}}<p><a href="{{url}}">{{url}}</a></p>{{/if}}
    </div>
    {{/each}}
  </section>
  {{/if}}

  <!-- Hidden plain text for ATS -->
  <div class="hidden">
    {{#if basics.summary}}{{basics.summary}} {{/if}}
    {{#each work}}
      {{position}} {{name}} {{#if startDate}}{{startDate}} {{/if}}{{#if endDate}}{{endDate}} {{/if}}{{summary}} {{#each highlights}}{{this}} {{/each}}
    {{/each}}
    {{#each education}}
      {{studyType}} {{area}} {{institution}} {{#if startDate}}{{startDate}} {{/if}}{{#if endDate}}{{endDate}} {{/if}}
    {{/each}}
    {{#each skills}}
      {{name}} {{#each keywords}}{{this}} {{/each}}
    {{/each}}
    {{#each projects}}
      {{name}} {{description}} {{#each highlights}}{{this}} {{/each}} {{#each keywords}}{{this}} {{/each}}
    {{/each}}
  </div>
</body>
</html>