#!/usr/bin/env node

const { Command } = require('commander');
const path = require('path');
const fs = require('fs');

const program = new Command();

program
  .name('json-cv')
  .description('Generate ATS-friendly resumes from JSON')
  .version('1.0.0');

program
  .option('-i, --input <file>', 'Path to JSON resume file', 'resume.json')
  .option('-t, --template <file>', 'Path to Handlebars template file')
  .option('-o, --out <file>', 'Output path for PDF', 'dist/resume.pdf')
  .option('-p, --preview', 'Start HTML preview server')
  .option('--open', 'Open browser when previewing')
  .option('-v, --validate', 'Validate JSON against IETF schema');

program.action(async (options) => {
  const inputPath = path.resolve(options.input);
  const templatePath = options.template ? path.resolve(options.template) : null;
  const outPath = path.resolve(options.out);

  if (!fs.existsSync(inputPath)) {
    console.error(`Input file not found: ${inputPath}`);
    process.exit(1);
  }

  if (options.validate) {
    const { validateResume } = require('../src/validate');
    const result = validateResume(inputPath);
    if (result.valid) {
      console.log('JSON is valid.');
    } else {
      console.error('Validation errors:');
      result.errors.forEach(err => console.error(`- ${err.message}`));
      process.exit(1);
    }
    return;
  }

  if (options.preview) {
    if (!templatePath || !fs.existsSync(templatePath)) {
      console.error('Template file required for preview.');
      process.exit(1);
    }
    const { startPreview } = require('../src/preview');
    await startPreview(inputPath, templatePath, options.open);
    return;
  }

  // Default: build PDF
  if (!templatePath || !fs.existsSync(templatePath)) {
    console.error('Template file required for build.');
    process.exit(1);
  }

  const { buildResume } = require('../src/build');
  await buildResume(inputPath, templatePath, outPath);
  console.log(`PDF generated: ${outPath}`);
});

program.parse();